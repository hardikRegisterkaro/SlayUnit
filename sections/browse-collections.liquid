{%- liquid
  assign limit = section.settings.collection_limit | default: 12
  assign title = section.settings.title | default: 'Browse Archives'
  assign eyebrow = section.settings.eyebrow | default: 'SELECT YOUR AESTHETIC'
-%}

<section class="browse-archives">
  <div class="browse-archives__header">
    <div>
      <h2 class="browse-archives__title">{{ title }}</h2>
      <p class="browse-archives__eyebrow">{{ eyebrow }}</p>
    </div>
    <div class="browse-archives__nav" aria-hidden="true">
      <button type="button" class="browse-archives__arrow" data-dir="prev" aria-label="Previous">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      </button>
      <button type="button" class="browse-archives__arrow" data-dir="next" aria-label="Next">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </button>
    </div>
  </div>

  <div class="browse-archives__track" data-archives-track>
    {%- for collection in collections limit: limit -%}
      {%- if collection.handle != 'frontpage' and collection.products_count > 0 -%}
        <a href="{{ collection.url }}" class="browse-archives__card">
          <div class="browse-archives__media">
            {%- if collection.image != blank -%}
              {{ collection.image | image_url: width: 600 | image_tag:
                loading: 'lazy',
                class: 'browse-archives__image',
                alt: collection.title }}
            {%- elsif collection.products.first.featured_media != blank -%}
              {{ collection.products.first.featured_media | image_url: width: 600 | image_tag:
                loading: 'lazy',
                class: 'browse-archives__image',
                alt: collection.title }}
            {%- else -%}
              <div class="browse-archives__placeholder"></div>
            {%- endif -%}
          </div>
          <div class="browse-archives__info">
            <span class="browse-archives__name">{{ collection.title }}</span>
            <span class="browse-archives__count">{{ collection.products_count }} {% if collection.products_count == 1 %}item{% else %}items{% endif %}</span>
          </div>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<script>
  (function () {
    const track = document.querySelector('[data-archives-track]');
    if (!track) return;
    const arrows = document.querySelectorAll('.browse-archives__arrow');
    arrows.forEach((btn) => {
      btn.addEventListener('click', () => {
        const card = track.querySelector('.browse-archives__card');
        const step = card ? card.getBoundingClientRect().width + 24 : 240;
        const dir = btn.dataset.dir === 'next' ? 1 : -1;
        track.scrollBy({ left: dir * step * 2, behavior: 'smooth' });
      });
    });
  })();
</script>

{% stylesheet %}
  .browse-archives {
    max-width: 1440px;
    margin: 0 auto;
    padding: 80px 36px;
    color: #111;
  }

  .browse-archives__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 40px;
  }

  .browse-archives__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 3rem;
    font-weight: 800;
    line-height: 1;
    margin: 0 0 6px;
    letter-spacing: -0.01em;
  }

  .browse-archives__eyebrow {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.55;
    margin: 0;
  }

  .browse-archives__nav {
    display: none;
    gap: 10px;
    flex-shrink: 0;
  }

  .browse-archives__arrow {
    width: 44px;
    height: 44px;
    border: 1px solid #111;
    border-radius: 50%;
    background: transparent;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #111;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .browse-archives__arrow:hover {
    background: #111;
    color: #fff;
  }

  .browse-archives__track {
    display: flex;
    gap: 48px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding: 0 36px;
    padding: 12px 10px 16px;
    margin: 0 -10px;
    scrollbar-width: none;
  }

  .browse-archives__track::-webkit-scrollbar {
    display: none;
  }

  .browse-archives__card {
    flex: 0 0 auto;
    width: 220px;
    text-decoration: none;
    color: inherit;
    scroll-snap-align: start;
  }

  .browse-archives__media {
    position: relative;
    width: 220px;
    height: 220px;
    border-radius: 50%;
    overflow: hidden;
    border: 1.5px solid #111;
    background: #f4f4f4;
    box-shadow: 0 0 0 6px #fff, 0 0 0 7px #111;
    transition: transform 0.4s ease;
  }

  .browse-archives__card:hover .browse-archives__media {
    transform: scale(1.03);
  }

  .browse-archives__image,
  .browse-archives__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .browse-archives__placeholder {
    background: linear-gradient(135deg, #ddd, #f4f4f4);
  }

  .browse-archives__info {
    text-align: center;
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .browse-archives__name {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .browse-archives__count {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 0.72rem;
    opacity: 0.55;
  }

  @media (max-width: 749px) {
    .browse-archives {
      padding: 56px 16px;
    }

    .browse-archives__title {
      font-size: 2rem;
    }

    .browse-archives__nav {
      display: none;
    }

    .browse-archives__card,
    .browse-archives__media {
      width: 160px;
    }

    .browse-archives__media {
      height: 160px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Browse collections",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Browse Archives" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "SELECT YOUR AESTHETIC" },
    {
      "type": "range",
      "id": "collection_limit",
      "label": "Max collections",
      "min": 2, "max": 16, "step": 1, "default": 12
    }
  ],
  "presets": [{ "name": "Browse collections" }]
}
{% endschema %}
