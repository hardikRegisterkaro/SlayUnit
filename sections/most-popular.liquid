{%- liquid
  assign limit = section.settings.product_limit | default: 8
  assign collection = collections[section.settings.collection]
-%}

{% render 'quick-add-styles' %}
{% render 'quick-add-modal-styles' %}
{% render 'product-badges-styles' %}

<section class="most-popular">
  <div class="most-popular__inner">
    <header class="most-popular__header">
      <div>
        <h2 class="most-popular__title">{{ section.settings.title }}</h2>
        <p class="most-popular__eyebrow">{{ section.settings.eyebrow }}</p>
      </div>
      <div class="most-popular__nav" aria-hidden="true">
        <button type="button" class="most-popular__arrow" data-dir="prev" aria-label="Previous">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        </button>
        <button type="button" class="most-popular__arrow" data-dir="next" aria-label="Next">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </div>
    </header>

    <div class="most-popular__track" data-popular-track>
      {%- for product in collection.products limit: limit -%}
        <div class="most-popular__item">
          {% # theme-check-disable UniqueStaticBlockId %}
          {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: product %}
          {% # theme-check-enable UniqueStaticBlockId %}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  (function () {
    const track = document.querySelector('[data-popular-track]');
    if (!track) return;
    const arrows = document.querySelectorAll('.most-popular__arrow');
    arrows.forEach((btn) => {
      btn.addEventListener('click', () => {
        const card = track.querySelector('.most-popular__item');
        const step = card ? card.getBoundingClientRect().width + 28 : 280;
        const dir = btn.dataset.dir === 'next' ? 1 : -1;
        track.scrollBy({ left: dir * step * 2, behavior: 'smooth' });
      });
    });
  })();
</script>

{% stylesheet %}
  .most-popular {
    background: #fff;
    color: #111;
  }

  .most-popular__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 80px 36px;
  }

  .most-popular__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 40px;
  }

  .most-popular__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 3rem;
    font-weight: 800;
    line-height: 1;
    margin: 0 0 6px;
    letter-spacing: -0.01em;
  }

  .most-popular__eyebrow {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.55;
    margin: 0;
  }

  .most-popular__nav {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
  }

  .most-popular__arrow {
    width: 44px;
    height: 44px;
    border: 1px solid #111;
    border-radius: 50%;
    background: transparent;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #111;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .most-popular__arrow:hover {
    background: #111;
    color: #fff;
  }

  .most-popular__track {
    display: flex;
    gap: 28px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding: 0 36px;
    padding-bottom: 8px;
    scrollbar-width: none;
  }

  .most-popular__track::-webkit-scrollbar {
    display: none;
  }

  .most-popular__item {
    flex: 0 0 calc((100% - 28px * 3) / 4);
    scroll-snap-align: start;
    min-width: 0;
  }

  .most-popular__item > product-card {
    width: 100%;
    display: block;
  }

  @media (max-width: 1100px) {
    .most-popular__item {
      flex: 0 0 calc((100% - 28px * 2) / 3);
    }
  }

  @media (max-width: 749px) {
    .most-popular__inner {
      padding: 56px 16px;
    }

    .most-popular__title {
      font-size: 2rem;
    }

    .most-popular__arrow {
      width: 36px;
      height: 36px;
    }

    .most-popular__item {
      flex: 0 0 calc((100% - 16px) / 2);
    }

    .most-popular__track {
      gap: 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Most popular",
  "blocks": [
    { "type": "_product-card" }
  ],
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Most Popular" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "SHOP THE BESTSELLERS" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "label": "Max products", "min": 4, "max": 16, "step": 1, "default": 8 }
  ],
  "presets": [
    {
      "name": "Most popular",
      "blocks": {
        "static-product-card": {
          "type": "_product-card",
          "name": "Product card",
          "static": true,
          "settings": {
            "product_card_gap": 4
          },
          "blocks": {
            "product-card-gallery": {
              "type": "_product-card-gallery",
              "settings": {
                "image_ratio": "adapt",
                "border": "none",
                "border_width": 1,
                "border_opacity": 100,
                "border_radius": 0
              }
            },
            "product_title": {
              "type": "product-title",
              "settings": {
                "width": "fit-content",
                "alignment": "left",
                "type_preset": "paragraph",
                "font_size": "1rem",
                "case": "uppercase",
                "color": "var(--color-foreground)",
                "padding-block-start": 8,
                "padding-block-end": 0
              }
            },
            "price": {
              "type": "price",
              "settings": {
                "show_sale_price_first": true,
                "type_preset": "h6",
                "alignment": "left",
                "font_size": "1rem",
                "color": "var(--color-foreground)",
                "padding-block-start": 0,
                "padding-block-end": 0
              }
            }
          },
          "block_order": ["product-card-gallery", "product_title", "price"]
        }
      }
    }
  ]
}
{% endschema %}
