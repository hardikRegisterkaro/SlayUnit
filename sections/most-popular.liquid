{%- liquid
  assign limit = section.settings.product_limit | default: 8
  assign collection = collections[section.settings.collection]
-%}

<section class="most-popular">
  <div class="most-popular__inner">
    <header class="most-popular__header">
      <div>
        <h2 class="most-popular__title">{{ section.settings.title }}</h2>
        <p class="most-popular__eyebrow">{{ section.settings.eyebrow }}</p>
      </div>
      <div class="most-popular__nav" aria-hidden="true">
        <button type="button" class="most-popular__arrow" data-dir="prev" aria-label="Previous">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        </button>
        <button type="button" class="most-popular__arrow" data-dir="next" aria-label="Next">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </div>
    </header>

    <div class="most-popular__track" data-popular-track>
      {%- for product in collection.products limit: limit -%}
        <a href="{{ product.url }}" class="most-popular__card">
          <div class="most-popular__media">
            {%- if product.featured_media != blank -%}
              {{ product.featured_media | image_url: width: 700 | image_tag:
                loading: 'lazy',
                class: 'most-popular__image',
                alt: product.title }}
            {%- endif -%}
            <wishlist-button
              class="wishlist-btn most-popular__wishlist"
              data-product-id="{{ product.id }}"
              data-handle="{{ product.handle }}"
              data-title="{{ product.title | escape }}"
              data-price="{{ product.price | money }}"
              data-image="{{ product.featured_media | image_url: width: 400 }}"
              data-url="{{ product.url }}"
              aria-label="Add to wishlist"
              aria-pressed="false"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </wishlist-button>
          </div>
          <div class="most-popular__info">
            <h3 class="most-popular__name">{{ product.title }}</h3>
            <span class="most-popular__price">{{ product.price | money }}</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  (function () {
    const track = document.querySelector('[data-popular-track]');
    if (!track) return;
    const arrows = document.querySelectorAll('.most-popular__arrow');
    arrows.forEach((btn) => {
      btn.addEventListener('click', () => {
        const card = track.querySelector('.most-popular__card');
        const step = card ? card.getBoundingClientRect().width + 28 : 280;
        const dir = btn.dataset.dir === 'next' ? 1 : -1;
        track.scrollBy({ left: dir * step * 2, behavior: 'smooth' });
      });
    });
  })();
</script>

{% stylesheet %}
  .most-popular {
    background: #fff;
    color: #111;
  }

  .most-popular__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 80px 36px;
  }

  .most-popular__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 40px;
  }

  .most-popular__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 3rem;
    font-weight: 800;
    line-height: 1;
    margin: 0 0 6px;
    letter-spacing: -0.01em;
  }

  .most-popular__eyebrow {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.55;
    margin: 0;
  }

  .most-popular__nav {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
  }

  .most-popular__arrow {
    width: 44px;
    height: 44px;
    border: 1px solid #111;
    border-radius: 50%;
    background: transparent;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #111;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .most-popular__arrow:hover {
    background: #111;
    color: #fff;
  }

  .most-popular__track {
    display: flex;
    gap: 28px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding: 0 36px;
    padding-bottom: 8px;
    scrollbar-width: none;
  }

  .most-popular__track::-webkit-scrollbar {
    display: none;
  }

  .most-popular__card {
    flex: 0 0 calc((100% - 28px * 3) / 4);
    text-decoration: none;
    color: inherit;
    scroll-snap-align: start;
  }

  .most-popular__media {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    background: #f4f4f4;
    overflow: hidden;
    margin-bottom: 14px;
  }

  .most-popular__wishlist {
    position: absolute;
    top: 12px;
    left: 12px;
    width: auto;
    height: auto;
    padding: 0;
    background: transparent;
    border: none;
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.35));
    transition: color 0.15s ease;
  }

  .most-popular__wishlist:hover {
    color: #d8362a;
  }

  .most-popular__wishlist[aria-pressed="true"] {
    color: #d8362a;
  }

  .most-popular__wishlist[aria-pressed="true"] svg {
    fill: currentColor;
  }

  .most-popular__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .most-popular__card:hover .most-popular__image {
    transform: scale(1.04);
  }

  .most-popular__info {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .most-popular__name {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0;
  }

  .most-popular__price {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    opacity: 0.75;
  }

  @media (max-width: 1100px) {
    .most-popular__card {
      flex: 0 0 calc((100% - 28px * 2) / 3);
    }
  }

  @media (max-width: 749px) {
    .most-popular__inner {
      padding: 56px 16px;
    }

    .most-popular__title {
      font-size: 2rem;
    }

    .most-popular__arrow {
      width: 36px;
      height: 36px;
    }

    .most-popular__card {
      flex: 0 0 calc((100% - 16px) / 2);
    }

    .most-popular__track {
      gap: 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Most popular",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Most Popular" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "SHOP THE BESTSELLERS" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "label": "Max products", "min": 4, "max": 16, "step": 1, "default": 8 }
  ],
  "presets": [{ "name": "Most popular" }]
}
{% endschema %}
