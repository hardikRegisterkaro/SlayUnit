{% assign form_id = 'ContactForm-' | append: section.id %}
{% assign address_lines = section.settings.address | newline_to_br | split: '<br />' %}
{% assign subject_options = section.settings.subject_options | newline_to_br | split: '<br />' %}

<section class="su-contact" aria-labelledby="su-contact-title">
  <header class="su-contact__hero">
    <h1 class="su-contact__title" id="su-contact-title">{{ section.settings.title }}</h1>
    {% if section.settings.tagline != blank %}
      <p class="su-contact__tagline">{{ section.settings.tagline }}</p>
    {% endif %}
  </header>

  <hr class="su-contact__rule su-contact__rule--bleed">

  <div class="su-contact__main">
    <aside class="su-contact__info" aria-label="Contact details">
      {% if section.settings.email_contact != blank %}
        <div class="su-contact__block">
          <h2 class="su-contact__label"><span class="su-contact__dot" aria-hidden="true"></span>REACH</h2>
          <p class="su-contact__email"><a href="mailto:{{ section.settings.email_contact }}">{{ section.settings.email_contact }}</a></p>
        </div>
      {% endif %}

      {% if section.settings.location_name != blank or section.settings.address != blank %}
        <div class="su-contact__block">
          <h2 class="su-contact__label"><span class="su-contact__dot" aria-hidden="true"></span>VISIT</h2>
          <address class="su-contact__address">
            {% if section.settings.location_name != blank %}
              <strong>{{ section.settings.location_name }}</strong>
            {% endif %}
            {% for line in address_lines %}
              {% assign trimmed = line | strip %}
              {% if trimmed != blank %}<span>{{ trimmed }}</span>{% endif %}
            {% endfor %}
          </address>
        </div>
      {% endif %}

      {% if section.settings.phone != blank %}
        <div class="su-contact__block">
          <h2 class="su-contact__label"><span class="su-contact__dot" aria-hidden="true"></span>PHONE</h2>
          <p class="su-contact__phone"><a href="tel:{{ section.settings.phone | replace: ' ', '' | replace: '-', '' }}">{{ section.settings.phone }}</a></p>
          {% if section.settings.phone_hours != blank %}
            <p class="su-contact__phone-hours">{{ section.settings.phone_hours }}</p>
          {% endif %}
        </div>
      {% endif %}

      <div class="su-contact__block">
        <h2 class="su-contact__label"><span class="su-contact__dot" aria-hidden="true"></span>FOLLOW</h2>
        <dl class="su-contact__list">
          {% if section.settings.instagram_handle != blank %}
            <dt>INSTAGRAM</dt>
            <dd>{% if section.settings.instagram_url != blank %}<a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener">{{ section.settings.instagram_handle }}</a>{% else %}{{ section.settings.instagram_handle }}{% endif %}</dd>
          {% endif %}
          {% if section.settings.twitter_handle != blank %}
            <dt>TWITTER / X</dt>
            <dd>{% if section.settings.twitter_url != blank %}<a href="{{ section.settings.twitter_url }}" target="_blank" rel="noopener">{{ section.settings.twitter_handle }}</a>{% else %}{{ section.settings.twitter_handle }}{% endif %}</dd>
          {% endif %}
        </dl>
      </div>
    </aside>

    <div class="su-contact__form-wrap">
      <div class="su-contact__form-head">
        <h2 class="su-contact__form-title">{{ section.settings.form_title }}</h2>
        <span class="su-contact__form-meta">* REQUIRED</span>
      </div>
      <hr class="su-contact__rule">

      {%- form 'contact', id: form_id, class: 'su-contact__form' -%}
        <input name="contact[id]" type="hidden" value="{{ form_id }}">

        {%- if form.errors and form.id == form_id -%}
          <div class="su-contact__alert su-contact__alert--error" tabindex="-1" autofocus>
            {{- form.errors | default_errors -}}
          </div>
        {%- endif -%}

        {%- if form.posted_successfully? and form.id == form_id -%}
          <div class="su-contact__alert su-contact__alert--success" tabindex="-1" autofocus>
            {{- 'blocks.contact_form.post_success' | t -}}
          </div>
        {%- endif -%}

        <div class="su-contact__row su-contact__row--2">
          <div class="su-contact__field">
            <label for="ContactForm-name-{{ section.id }}">NAME <span aria-hidden="true">*</span></label>
            <input
              type="text"
              id="ContactForm-name-{{ section.id }}"
              name="contact[name]"
              autocomplete="name"
              placeholder="Mee Tory"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              required
            >
          </div>
          <div class="su-contact__field">
            <label for="ContactForm-email-{{ section.id }}">EMAIL <span aria-hidden="true">*</span></label>
            <input
              type="email"
              id="ContactForm-email-{{ section.id }}"
              name="contact[email]"
              autocomplete="email"
              spellcheck="false"
              autocapitalize="off"
              placeholder="you@domain.com"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              required
              aria-required="true"
            >
          </div>
        </div>

        <div class="su-contact__field">
          <label for="ContactForm-subject-{{ section.id }}">SUBJECT <span aria-hidden="true">*</span></label>
          <div class="su-contact__select-wrap">
            <select id="ContactForm-subject-{{ section.id }}" name="contact[subject]" required>
              <option value="" disabled {% if form.subject == blank %}selected{% endif %}>Select a category…</option>
              {% for opt in subject_options %}
                {% assign opt_value = opt | strip %}
                {% if opt_value != blank %}
                  <option value="{{ opt_value }}" {% if form.subject == opt_value %}selected{% endif %}>{{ opt_value }}</option>
                {% endif %}
              {% endfor %}
            </select>
            <svg class="su-contact__select-caret" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>

        <div class="su-contact__field">
          <label for="ContactForm-order-{{ section.id }}">ORDER NUMBER <span class="su-contact__optional">— IF APPLICABLE</span></label>
          <input
            type="text"
            id="ContactForm-order-{{ section.id }}"
            name="contact[order_number]"
            placeholder="SU-XXXX-XXXXX"
            value="{{ form.order_number }}"
          >
        </div>

        <div class="su-contact__field">
          <label for="ContactForm-body-{{ section.id }}">MESSAGE <span aria-hidden="true">*</span></label>
          <textarea
            rows="6"
            id="ContactForm-body-{{ section.id }}"
            name="contact[body]"
            placeholder="Type your transmission here…"
            required
          >{{- form.body -}}</textarea>
        </div>

        <div class="su-contact__submit-row">
          <label class="su-contact__consent">
            <input type="checkbox" name="contact[consent]" required>
            <span class="su-contact__consent-box" aria-hidden="true"></span>
            <span class="su-contact__consent-text">I AGREE TO {% if section.settings.privacy_url != blank %}<a href="{{ section.settings.privacy_url }}">PRIVACY POLICY</a>{% else %}PRIVACY POLICY{% endif %} &amp; {% if section.settings.terms_url != blank %}<a href="{{ section.settings.terms_url }}">TERMS OF SERVICE</a>{% else %}TERMS OF SERVICE{% endif %}.</span>
          </label>

          <button type="submit" class="su-contact__submit">
            <span>{{ section.settings.submit_label }}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>

  {% if section.blocks.size > 0 %}
    <hr class="su-contact__rule su-contact__rule--bleed su-contact__rule--gap">

    <div class="su-contact__faq">
      <div class="su-contact__faq-head">
        <div>
          <p class="su-contact__eyebrow"><span class="su-contact__dot" aria-hidden="true"></span>{{ section.settings.faq_eyebrow }}</p>
          <h2 class="su-contact__faq-title">{{ section.settings.faq_title }}</h2>
        </div>
        {% if section.settings.faq_meta != blank %}
          <p class="su-contact__faq-meta">{{ section.settings.faq_meta | newline_to_br }}</p>
        {% endif %}
      </div>

      <dl class="su-contact__faq-list">
        {% for block in section.blocks %}
          {% if block.type == 'faq_item' %}
            <div class="su-contact__faq-row" {{ block.shopify_attributes }}>
              <span class="su-contact__faq-num" aria-hidden="true">{{ forloop.index | prepend: '00' | slice: -2, 2 }}</span>
              <dt class="su-contact__faq-q">{{ block.settings.question }}</dt>
              <dd class="su-contact__faq-a">{{ block.settings.answer }}</dd>
            </div>
          {% endif %}
        {% endfor %}
      </dl>
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .su-contact {
    --su-mono: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
    --su-rule: #a3a3a3;
    --su-rule-soft: rgb(0 0 0 / 0.15);
    --su-muted: rgb(0 0 0 / 0.55);

    max-width: 1280px;
    margin-inline: auto;
    padding: 40px 32px 56px;
    color: #000;
  }

  /* HERO */
  .su-contact__hero {
    text-align: center;
    padding: 8px 0 28px;
  }

  .su-contact__title {
    font-weight: 900;
    font-size: clamp(3rem, 9vw, 6.5rem);
    line-height: 0.9;
    letter-spacing: -0.05em;
    margin: 0 0 14px;
    text-transform: uppercase;
  }

  .su-contact__tagline {
    font-family: var(--su-mono);
    font-size: 0.74rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #000;
    margin: 0 auto;
    max-width: 520px;
    line-height: 1.55;
  }

  /* RULES */
  .su-contact__rule {
    border: 0;
    border-top: 1px solid var(--su-rule);
    margin: 0;
  }
  .su-contact__rule--bleed {
    margin-inline: calc(50% - 50vw);
  }
  .su-contact__rule--gap {
    margin-top: 48px;
  }

  /* MAIN GRID */
  .su-contact__main {
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
    padding: 32px 0;
  }
  @media (min-width: 900px) {
    .su-contact__main {
      grid-template-columns: minmax(220px, 260px) 1fr;
      gap: 56px;
    }
  }

  /* INFO COLUMN */
  .su-contact__info {
    display: flex;
    flex-direction: column;
    gap: 24px;
    font-family: var(--su-mono);
    font-size: 0.78rem;
    line-height: 1.5;
  }

  .su-contact__block {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .su-contact__label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--su-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0;
    font-weight: 700;
  }

  .su-contact__dot {
    display: inline-block;
    width: 9px;
    height: 9px;
    background: #000;
  }

  .su-contact__list {
    margin: 0;
    display: grid;
    grid-template-columns: max-content;
    row-gap: 8px;
  }
  .su-contact__list dt {
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    color: var(--su-muted);
    margin-bottom: -4px;
  }
  .su-contact__list dd {
    margin: 0 0 6px;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.02em;
  }
  .su-contact__list a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s ease;
  }
  .su-contact__list a:hover {
    border-bottom-color: #000;
  }

  .su-contact__phone,
  .su-contact__email {
    margin: 0;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.02em;
  }
  .su-contact__phone a,
  .su-contact__email a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s ease;
  }
  .su-contact__phone a:hover,
  .su-contact__email a:hover {
    border-bottom-color: #000;
  }
  .su-contact__phone-hours {
    margin: 4px 0 0;
    font-size: 0.72rem;
    color: var(--su-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .su-contact__address {
    display: flex;
    flex-direction: column;
    font-style: normal;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    gap: 2px;
  }
  .su-contact__address strong {
    font-weight: 700;
    margin-bottom: 6px;
  }

  /* FORM */
  .su-contact__form-wrap {
    display: flex;
    flex-direction: column;
  }

  .su-contact__form-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 14px;
  }
  .su-contact__form-title {
    font-weight: 800;
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin: 0;
  }
  .su-contact__form-meta {
    font-family: var(--su-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: var(--su-muted);
    text-transform: uppercase;
  }

  .su-contact__form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-top: 20px;
  }

  .su-contact__row--2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 600px) {
    .su-contact__row--2 { grid-template-columns: 1fr 1fr; }
  }

  .su-contact__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .su-contact__field label {
    font-family: var(--su-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #000;
    font-weight: 700;
  }

  .su-contact__optional {
    font-weight: 400;
    color: var(--su-muted);
    letter-spacing: 0.12em;
  }

  .su-contact__field input,
  .su-contact__field textarea,
  .su-contact__field select {
    width: 100%;
    background: #fff;
    border: 1px solid var(--su-rule-soft);
    padding: 10px 14px;
    font-size: 0.9rem;
    font-family: inherit;
    color: #000;
    border-radius: 0;
    transition: border-color 0.15s ease;
    -webkit-appearance: none;
    appearance: none;
  }

  .su-contact__field input::placeholder,
  .su-contact__field textarea::placeholder {
    color: rgb(0 0 0 / 0.3);
  }

  .su-contact__field input:focus,
  .su-contact__field textarea:focus,
  .su-contact__field select:focus {
    outline: none;
    border-color: #000;
  }

  .su-contact__field textarea {
    resize: vertical;
    min-height: 110px;
    line-height: 1.5;
  }

  .su-contact__select-wrap {
    position: relative;
  }
  .su-contact__select-wrap select {
    padding-right: 40px;
    cursor: pointer;
  }
  .su-contact__select-caret {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: rgb(0 0 0 / 0.5);
  }

  /* SUBMIT ROW */
  .su-contact__submit-row {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 4px;
  }
  @media (min-width: 600px) {
    .su-contact__submit-row {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .su-contact__consent {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    cursor: pointer;
    font-family: var(--su-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #000;
    line-height: 1.5;
  }
  .su-contact__consent input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .su-contact__consent-box {
    flex-shrink: 0;
    width: 14px;
    height: 14px;
    border: 1px solid #000;
    margin-top: 2px;
    position: relative;
    background: #fff;
  }
  .su-contact__consent input:checked + .su-contact__consent-box::after {
    content: '';
    position: absolute;
    inset: 2px;
    background: #000;
  }
  .su-contact__consent input:focus-visible + .su-contact__consent-box {
    outline: 2px solid #000;
    outline-offset: 2px;
  }
  .su-contact__consent a {
    color: inherit;
    text-decoration: underline;
  }

  .su-contact__submit {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 12px 22px;
    background: #000;
    color: #fff;
    border: 0;
    font-family: var(--su-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .su-contact__submit:hover {
    background: #222;
  }
  .su-contact__submit:active {
    transform: translateY(1px);
  }
  .su-contact__submit svg {
    transition: transform 0.2s ease;
  }
  .su-contact__submit:hover svg {
    transform: translateX(3px);
  }

  /* ALERTS */
  .su-contact__alert {
    font-family: var(--su-mono);
    font-size: 0.78rem;
    padding: 14px 16px;
    border: 1px solid;
    line-height: 1.5;
  }
  .su-contact__alert--error {
    border-color: #b91c1c;
    color: #b91c1c;
  }
  .su-contact__alert--success {
    border-color: #166534;
    color: #166534;
  }

  /* FAQ */
  .su-contact__faq {
    padding-top: 32px;
  }

  .su-contact__faq-head {
    display: flex;
    flex-direction: column;
    gap: 16px;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 20px;
  }
  @media (min-width: 800px) {
    .su-contact__faq-head {
      flex-direction: row;
      align-items: flex-end;
    }
  }

  .su-contact__eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--su-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 12px;
    font-weight: 700;
  }

  .su-contact__faq-title {
    font-size: clamp(2.5rem, 6.5vw, 4.5rem);
    line-height: 0.9;
    letter-spacing: -0.045em;
    font-weight: 900;
    margin: 0;
    text-transform: uppercase;
  }

  .su-contact__faq-meta {
    font-family: var(--su-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #000;
    text-align: left;
    margin: 0;
    line-height: 1.6;
  }
  @media (min-width: 800px) {
    .su-contact__faq-meta { text-align: right; }
  }

  .su-contact__faq-list {
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .su-contact__faq-row {
    display: grid;
    grid-template-columns: 32px 1fr;
    column-gap: 18px;
    row-gap: 10px;
    padding: 18px 0;
    border-bottom: 1px solid var(--su-rule-soft);
  }
  @media (min-width: 800px) {
    .su-contact__faq-row {
      grid-template-columns: 36px minmax(260px, 1fr) 1.4fr;
      column-gap: 24px;
      align-items: start;
    }
  }

  .su-contact__faq-num {
    font-family: var(--su-mono);
    font-size: 0.72rem;
    color: var(--su-muted);
    letter-spacing: 0.08em;
    padding-top: 4px;
  }

  .su-contact__faq-q {
    margin: 0;
    font-weight: 800;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    line-height: 1.4;
  }

  .su-contact__faq-a {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.6;
    color: #000;
  }
  @media (max-width: 799px) {
    .su-contact__faq-a {
      grid-column: 2 / -1;
    }
  }

  /* MOBILE */
  @media (max-width: 749px) {
    .su-contact {
      padding: 28px 20px 48px;
    }
    .su-contact__hero {
      padding: 4px 0 20px;
    }
    .su-contact__main {
      padding: 24px 0;
      gap: 28px;
    }
    .su-contact__rule--gap {
      margin-top: 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact page",
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "title", "label": "Title", "default": "CONTACT" },
    { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "Reach the collective — no middle layer. No bots. No forms that disappear into the void." },

    { "type": "header", "content": "Reach (email)" },
    { "type": "text", "id": "email_contact", "label": "Contact email", "default": "connect@slayunit.com" },

    { "type": "header", "content": "Visit" },
    { "type": "text", "id": "location_name", "label": "Location name", "default": "Scaleverge Solutions Pvt. Ltd." },
    { "type": "textarea", "id": "address", "label": "Address (one line per row)", "default": "Plot 68, Inst. Area, Sector 32\nGurugram, Haryana 122001" },

    { "type": "header", "content": "Phone" },
    { "type": "text", "id": "phone", "label": "Phone number", "default": "+91 80 1234 5678" },
    { "type": "text", "id": "phone_hours", "label": "Phone hours", "default": "Mon — Sat · 10:00 — 19:00 IST" },

    { "type": "header", "content": "Follow" },
    { "type": "text", "id": "instagram_handle", "label": "Instagram handle", "default": "@slayunit_ofc" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "text", "id": "twitter_handle", "label": "Twitter / X handle", "default": "@slayunit" },
    { "type": "url", "id": "twitter_url", "label": "Twitter / X URL" },

    { "type": "header", "content": "Form" },
